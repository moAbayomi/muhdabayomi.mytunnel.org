<section>
    <% Object.keys(grouped).forEach(month => { %>
    <!-- Month Block Container -->
    <div id="month-block" class="mb-fluid-lg">
        
        <!-- Dynamic Month Label -->
        <p id="month-label" class="text-body py-fluid-md text-right text-text-muted">
            <%= month %>
        </p>
        
        <div>
            <!-- Loop through all entries for this specific month -->
            <% grouped[month].forEach(entry => { %>
                
                <!-- Format the specific day number (e.g., 28, 14) -->
                <% 
                    const dayNumber = new Intl.DateTimeFormat("en-US", { 
                        day: "numeric",
                        timeZone: "Africa/Lagos" 
                    }).format(new Date(entry.created_at));
                    
                    // Simple rule to add English day suffixes (st, nd, rd, th)
                    let suffix = "th";
                    if (dayNumber === "1" || dayNumber === "21" || dayNumber === "31") suffix = "st";
                    else if (dayNumber === "2" || dayNumber === "22") suffix = "nd";
                    else if (dayNumber === "3" || dayNumber === "23") suffix = "rd";
                %>

                <!-- Dynamic Entry Link -->
                <a href="/thoughts/<%= entry.slug || '#' %>" id="entry-row" class="text-text-body flex justify-between pb-4">
                    <p class="entry-title"><%= entry.title %></p>
                    <span class="entry-day"><%= dayNumber %><%= suffix %></span>
                </a>

            <% }); %>
        </div>

    </div>
<% }); %>

</section>

<section class="mt-fluid-lg">
	<a href="/" class="text-text-muted">&larr; home</a>
</section>